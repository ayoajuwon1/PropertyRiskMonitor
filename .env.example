# ==============================================================================
# NIGERIA PROPERTY RISK MONITOR (NPRM) - Environment Variables
# ==============================================================================

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NPRM_ALLOWED_ORIGIN=http://localhost:3000
# Land Republic CTA destination
NEXT_PUBLIC_LAND_REPUBLIC_PROPERTY_URL=https://landrepublic.co/properties
NEXT_PUBLIC_LAND_REPUBLIC_INSPECTION_URL=https://landrepublic.co/properties

# Optional: override map style (MapLibre-compatible style URL)
# NEXT_PUBLIC_MAP_STYLE_URL=https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json
# Optional: explicit light/dark styles (recommended)
# NEXT_PUBLIC_MAP_STYLE_DARK_URL=https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json
# NEXT_PUBLIC_MAP_STYLE_LIGHT_URL=https://basemaps.cartocdn.com/gl/positron-gl-style/style.json

# Composite score weights
FLOOD_WEIGHT=0.25
INFRA_WEIGHT=0.10
NIGHTLIGHT_WEIGHT=0.07
RAINFALL_WEIGHT=0.15
POPULATION_WEIGHT=0.08
SECURITY_WEIGHT=0.35

# Security intelligence pipeline (Nigeria-native)
# Set to false to temporarily disable v2 pipeline and fall back to legacy deterministic security job
SECURITY_INTEL_V2=true
# Set true to force quarterly publish write without waiting for new quarter stamp
FORCE_SECURITY_PUBLISH=false
# Optional Gemini extraction (falls back to heuristics if unset)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
# Optional ACLED connector (falls back to Google-only if unset)
# ACLED_API_KEY=
# ACLED_EMAIL=
# ACLED_ENDPOINT=https://api.acleddata.com/acled/read

# Optional deployment/database placeholders for Phase 1 extension
# DATABASE_URL=postgresql://...
# SUPABASE_URL=https://...
# SUPABASE_SERVICE_ROLE_KEY=...
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# S3_BUCKET=...
